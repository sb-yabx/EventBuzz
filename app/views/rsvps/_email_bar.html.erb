<div id="emailModal" class="modal-overlay" style="display:none;">
  <div class="modal-box">

    <h4>Send Email</h4>

    <form id="emailForm" method="post">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div class="mb-3">
        <label>Subject</label>
        <input type="text" name="subject" class="form-control" required>
      </div>

      <div class="mb-3">
        <label>Message</label>
        <textarea name="message" class="form-control" rows="5" required></textarea>
      </div>

   <div class="mb-3">
  <label>Send To</label>
  <select name="target" id="targetSelect" class="form-control" onchange="toggleGuestSelect()">
    <option value="all">All Guests</option>
    <option value="pending">Pending Guests</option>
    <option value="attending">Attending Guests</option>
    <option value="individual">Individual Guest</option>
  </select>
</div>


<div class="mb-3" id="guestSelectBox" style="display:none; margin-top:15px;">
  <label class="form-label fw-semibold">Select Guests</label>

  <!-- Container -->
  <div class="email-container">

    <!-- Select All -->
    <div style="margin-bottom:10px; border-bottom:1px solid #ddd; padding-bottom:8px;">
      <input type="checkbox" onclick="toggleAll(this)" id="selectAll">
      <label for="selectAll" style="margin-left:6px; font-weight:500;">
        Select All Guests
      </label>
    </div>

    <!-- Guest List -->
    <% @event.guests.each do |guest| %>
      <label style="
        display:flex;
        align-items:center;
        padding:8px;
        border-radius:6px;
        cursor:pointer;
        transition: background 0.2s;
      "
      onmouseover="this.style.background='#f0f0f0'"
      onmouseout="this.style.background='transparent'"
      >
        <input type="checkbox" name="guest_ids[]" value="<%= guest.id %>" style="margin-right:10px;">
        
        <span style="font-size:14px;">
          <%= guest.email %>
        </span>
      </label>
    <% end %>

  </div>
</div>

    <button type="button" class="btn btn-secondary"  
    onclick="previewEmail()">
  Preview
</button>

      <button type="submit" class="btn btn-dark">Send</button>
      <button type="button" class="btn btn-secondary" onclick="closeEmailModal()">Cancel</button>
    </form>


  <div id="previewBox" style="display:none; margin-top:20px;">
  <h5>Email Preview</h5>

  <div class="card p-3">
    <h6 id="previewSubject"></h6>
    <hr>
    <p id="previewMessage"></p>

    <small>
      <strong>Event:</strong> <span id="previewEvent"></span><br>
      <strong>Date:</strong> <span id="previewDate"></span>
    </small>
  </div>
</div>

  </div>
</div>