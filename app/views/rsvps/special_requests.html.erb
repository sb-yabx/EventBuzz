<div class="rsvp-dashboard">
  <div class="text-end">
     <%= link_to "← Back", request.referer || root_path, class: "btn bg-dark btn-dark rounded-pill px-3" %>
     <%= link_to "Download file", download_pdf_special_requests_event_rsvps_path(@event), class: "btn btn-outline-dark rounded-pill px-4" %>
     </div>
  <h2>Special Requests for <%= @event.name %></h2>
  

  <table class="rsvp-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Request</th>
      </tr>
    </thead>

    <tbody>
      <% if @rsvps.any? %>
        <% @rsvps.each do |rsvp| %>
          <tr>
            <td><%= rsvp.user&.name || "Guest" %></td>
            <td><%= rsvp.user&.email %></td>
            <td><%= rsvp.special_request %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="3" class="text-center text-muted py-4">
            🚫 No special requests found
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

</div>