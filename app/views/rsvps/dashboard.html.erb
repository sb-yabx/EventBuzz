
<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">RSVP Dashboard</h2>
  <div class="d-flex gap-2">
     <%= link_to "← Back", request.referer || root_path, class: "btn bg-dark btn-dark rounded-pill px-3" %>
   
     </div>
  </div>
  
  <div class="row g-4">
    <% @events.each do |event| %>
      <div class="col-md-4">
        <%= link_to event_rsvps_path(event), class: "text-decoration-none" do %>
          
          <div class="event-card">
            
            <!-- Top Gradient -->
            <div class="card-header-gradient">
              <h5><%= event.name %></h5>
            </div>

            <!-- Body -->
            <div class="card-body-custom">
              <p>
                📅 <strong><%= event.date.strftime("%d %b %Y") %></strong>
              </p>

              <p>
                📍 <%= event.venue.try(:name) || "No venue" %>
              </p>

              <div class="rsvp-count">
                <% if event.date < Date.today%>
                <small>Event done</small>
                <% else %>
                <span><%= event.rsvps.count %></span>
                <small>Responses</small>
                <%end%>
                
              </div>
            </div>

          </div>

        <% end %>
      </div>
    <% end %>
  </div>

</div>