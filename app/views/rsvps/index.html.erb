<div class="rsvp-dashboard">

  <h2>RSVPs for <%= @event.name %></h2>
  <div class="text-center mb-3">
  <%= link_to "Invite more",
      event_invite_guests_path(@event),
      class: "btn btn-dark" %>

      <%= link_to "Special Requests",
      special_requests_event_rsvps_path(@event),
      class: "btn btn-dark" %>

     <button 
  class="btn btn-dark"
  onclick="openEmailModal(
    <%= @event.id %>,
    '<%= j @event.name %>',
    '<%= j @event.date.strftime("%B %d, %Y") %>'
  )">
  Send email
</button>

    <%= link_to "← Back", request.referer || root_path, class: "btn bg-dark btn-dark rounded-pill px-3" %>

</div>

<div id="emailModal" class="modal-overlay" style="display:none;">
  <div class="modal-box">

    <h4>Send Email</h4>

    <form id="emailForm" method="post">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div class="mb-3">
        <label>Subject</label>
        <input type="text" name="subject" class="form-control" required>
      </div>

      <div class="mb-3">
        <label>Message</label>
        <textarea name="message" class="form-control" rows="5" required></textarea>
      </div>

   <div class="mb-3">
  <label>Send To</label>
  <select name="target" id="targetSelect" class="form-control" onchange="toggleGuestSelect()">
    <option value="all">All Guests</option>
    <option value="pending">Pending Guests</option>
    <option value="attending">Attending Guests</option>
    <option value="individual">Individual Guest</option>
  </select>
</div>

<!-- Hidden initially -->
<div class="mb-3" id="guestSelectBox" style="display:none;">
  <label>Select Guest</label>
  <select name="guest_id" class="form-control">
    <% @event.guests.each do |guest| %>
      <option value="<%= guest.id %>"><%= guest.email %></option>
    <% end %>
  </select>
</div>

    <button type="button" class="btn btn-secondary"  
    onclick="previewEmail()">
  Preview
</button>

      <button type="submit" class="btn btn-dark">Send</button>
      <button type="button" class="btn btn-secondary" onclick="closeEmailModal()">Cancel</button>
    </form>


  <div id="previewBox" style="display:none; margin-top:20px;">
  <h5>Email Preview</h5>

  <div class="card p-3">
    <h6 id="previewSubject"></h6>
    <hr>
    <p id="previewMessage"></p>

    <small>
      <strong>Event:</strong> <span id="previewEvent"></span><br>
      <strong>Date:</strong> <span id="previewDate"></span>
    </small>
  </div>
</div>

  </div>
</div>

<div class="filter-bar mb-4">
  <%= form_with url: event_rsvps_path(@event), method: :get, local: true do %>

    <div class="row g-3 align-items-end">

      <!-- STATUS -->
      <div class="col-md-2">
        <label class="filter-label">Status</label>
        <%= select_tag :status,
          options_for_select(
            [["All", ""]] + Rsvp.statuses.keys.map { |k| [k.humanize, k] },
            params[:status]
          ),
          class: "form-select" %>
      </div>

      <!-- PARKING -->
      <div class="col-md-2">
        <label class="filter-label">Parking</label>
        <%= select_tag :parking,
          options_for_select([["All", ""], ["Yes", "true"], ["No", "false"]], params[:parking]),
          class: "form-select" %>
      </div>

      <!-- ACCOMMODATION -->
      <div class="col-md-2">
        <label class="filter-label">Accommodation</label>
        <%= select_tag :accommodation,
          options_for_select([["All", ""], ["Yes", "true"], ["No", "false"]], params[:accommodation]),
          class: "form-select" %>
      </div>

      <!-- DIET -->
      <div class="col-md-2">
        <label class="filter-label">Diet</label>
        <%= select_tag :diet,
          options_for_select(
            [["All", ""]] + Rsvp.dietary_preferences.keys.map { |k| [k.humanize, k] },
            params[:diet]
          ),
          class: "form-select" %>
      </div>

      <!-- BUTTONS -->
      <div class="col-md-3 d-flex gap-2">
        <%= submit_tag "Filter", class: "btn btn-dark w-50" %>
        <%= link_to "Reset", event_rsvps_path(@event), class: "btn btn-outline-secondary w-50" %>
      </div>

    </div>

  <% end %>
</div>




  <table class="rsvp-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Status</th>
        <th>Diet</th>
        <th>Seating</th>
        <th>Parking</th>
        <th>Accommodation</th>
       
      </tr>
    </thead>

    <tbody>
        <% if @rsvps.any? %>
      <% @rsvps.each do |rsvp| %>
        <tr>
          <td><%= rsvp.user&.name || "Guest" %></td>
          <td><%= rsvp.user&.email %></td>
          <td>
            <span class="status <%= rsvp.status.downcase.gsub(" ", "-") %>">
              <%= rsvp.status %>
            </span>
          </td>
          <td><%= rsvp.dietary_preference %></td>
          <td><%= rsvp.seating_preference %></td>
          <td><%= rsvp.need_parking ? "Yes" : "No" %></td>
          <td><%= rsvp.need_accommodation ? "Yes" : "No" %></td>
         
          
        </tr>
      <% end %>
      <% else%>
      <tr>
      <td colspan="7" class="text-center text-muted py-4">
        🚫 No RSVPs found for selected filters
      </td>
    </tr>
      <%end%>
    </tbody>
  </table>

</div>