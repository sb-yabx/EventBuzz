<div class="container py-5">
<p>Total Guests: <%= @guests.count %></p>
  <!-- Back Button -->
  <div class="mb-4">
    <%= link_to "← Back", request.referer || root_path, 
        class: "btn btn-outline-dark rounded-pill px-4" %>
  </div>

  <div class="card shadow-lg border-0 rounded-4 p-4">

    <h3 class="fw-bold mb-4 text-center">Invited Guests</h3>

    <% if @guests.any? %>

      <div class="table-responsive">
        <table class="table table-hover align-middle">

          <thead class="table-dark">
            <tr>
              <th>#</th>
              <th>Email</th>
              <th>User ID</th>
              <th>Name</th>
              <th>Status</th>
              <th>RSVP status</th>
            </tr>
          </thead>

          <tbody>
            <% @guests.each_with_index do |guest, index| %>
              <tr>
                <td><%= index + 1 %></td>

                <td>
                  <span class="fw-semibold"><%= guest.email %></span>
                </td>

                <td>
                  <%= guest.user_id || "-" %>
                </td>

                <td>
                  <%= guest.user&.name || "—" %>
                </td>

                <td>
                  <% if guest.user_id.present? %>
                    <span class="badge bg-success">Registered</span>
                  <% else %>
                    <span class="badge bg-warning text-dark">Not created account yet!</span>
                  <% end %>
                </td>
                <td>
                <% if guest.user_id.present? %>

                    <% rsvp = Rsvp.find_by(user_id: guest.user_id, event_id: @event.id) %>

                    <% if rsvp %>
                    <span class="badge bg-success"><%= rsvp.status %></span>
                    <% else %>
                    <span class="badge bg-info text-dark">Registered (No RSVP)</span>
                    <% end %>

                <% else %>
                    <span class="badge bg-warning text-dark">Not registered</span>
                <% end %>
                </td>

              </tr>
            <% end %>
          </tbody>

        </table>
      </div>

    <% else %>

      <div class="text-center py-4">
        <p class="text-muted mb-3">No invites sent yet.</p>
        <%= link_to "Invite Guests", event_invite_guests_path(@event), 
              class: "btn btn-primary rounded-pill px-4" %>
      </div>

    <% end %>

  </div>
</div>