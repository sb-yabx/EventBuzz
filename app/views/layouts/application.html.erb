<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Event Buzz" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-cache">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">

    
    <!-- Styles -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "forms", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "home", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "event", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "rsvp", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "chat", "data-turbo-track": "reload" %>

    <%= javascript_include_tag "application", type: "module" %>
  </head>

  <body> 

    <%= render 'layouts/navbar' %>
    <%= yield %>
    

    <div id="flash-data" data-flash='<%= flash.to_hash.to_json %>'></div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    

  </body>
</html>