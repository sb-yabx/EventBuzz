<div class="container py-5">
<div class="d-flex justify-content-between align-items-center mb-4">
<h2 class="fw-bold mb-4 text-center">My Invitations</h2>
<div class="d-flex gap-2">
     <%= link_to "← Back", request.referer || root_path, class: "btn bg-dark btn-dark rounded-pill px-3" %>
     </div>
</div>

<div class="container">
  <div class="row g-4">
    
    <% @events.each do |event| %>
    
      <div class="col-md-4">
        
        <div class="card border-0 shadow-lg h-100 rounded-4 invite-card">
        <%= link_to event_path(event), class:"text-decoration-none" do %>
          <!-- Card Body -->
          <div class="card-body d-flex flex-column">

            <!-- Event Title -->
            <h5 class="fw-bold mb-2"><%= event.name %></h5>

            <!-- Description -->
            <p class="text-muted small flex-grow-1">
              <%= truncate(event.description, length: 100) %>
            </p>

            <% rsvp = event.rsvps.find_by(user_id: current_user.id) %>

            <!-- Status Badge -->
            <% if rsvp && !rsvp.pending? %>
              <span class="badge bg-success mb-3">
                ✔ RSVP Submitted
              </span>
              <% elsif event.date < Date.today%>
             <span class="badge bg-dark mb-3">
                RSVP not submiited
              </span>
            <% else %>
              <span class="badge bg-warning text-dark mb-3">
                Pending Response
              </span>
            <% end %>

            <!-- Button -->
            <% if rsvp && !rsvp.pending? %>
              <button class="btn btn-success w-100 rounded-pill" disabled>
                Submitted
              </button>
              <% elsif rsvp && rsvp.pending? && event.date > Date.today%>
               <%= link_to "Fill RSVP",
                  new_event_rsvp_path(event),
                  class: "btn btn-dark w-100 rounded-pill" %>
            <% else %>
              <button class="btn btn-dark w-100 rounded-pill" disabled>
                Event unattended
              </button>
            <% end %>

          </div>
           <% end %>
        </div>

      </div>
     
    <% end %>

  </div>
</div>
</div>