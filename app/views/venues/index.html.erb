<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">All Venues</h2>

    <%= link_to "Add New Venue", new_venue_path, class: "btn btn-success" %>
  </div>

  <div class="card shadow-sm">

    <div class="card-header bg-dark text-white">
      Venue List
    </div>

    <div class="card-body">

      <% if @venues.any? %>

      <table class="table table-hover table-striped align-middle">

        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Capacity</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>

        <% @venues.each do |venue| %>
          <tr>

            <td>
              <strong><%= venue.name %></strong>
            </td>

            <td>
              <%= venue.address %>
            </td>
             <td>
              <%= venue.capacity %>
            </td>

            <td>

              <%= link_to "Show", venue_path(venue), class: "btn btn-sm btn-outline-warning" %>

              <%= link_to "Delete", venue_path(venue),
                  method: :delete,
                  data: { confirm: "Are you sure?" },
                  class: "btn btn-sm btn-outline-danger" %>
            </td>

          </tr>
        <% end %>

        </tbody>

      </table>


      <% else %>

      <p class="text-center text-muted">No venues found.</p>

      <% end %>

    </div>

  </div>

</div>