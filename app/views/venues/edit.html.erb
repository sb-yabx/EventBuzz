<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card shadow-lg border-0">

<div class="card-header bg-dark text-white text-center">
<h4> Edit Venue</h4>
</div>

<div class="card-body">

<%= form_with model: @venue do |f| %>

<div class="mb-3">
<%= f.label :name, "Venue Name", class:"form-label" %>
<%= f.text_field :name, class:"form-control", placeholder:"Enter venue name" %>
</div>

<div class="mb-3">
<%= f.label :address, class:"form-label" %>
<%= f.text_field :address, class:"form-control", placeholder:"Enter venue address" %>
</div>

<div class="mb-3">
<%= f.label :capacity, class:"form-label" %>
<%= f.number_field :capacity, class:"form-control", placeholder:"Enter seating capacity" %>
</div>

<div class="mb-3">
<%= f.label :facilities, class:"form-label" %>
<%= f.text_area :facilities, class:"form-control", placeholder:"Enter facilities available" %>
</div>

<div class="mb-3">
<%= f.label :contact, class:"form-label" %>
<%= f.number_field :contact, class:"form-control", placeholder:"Enter contact number" %>
</div>

<div class="d-grid">
<%= f.submit "Update", class:"btn btn-primary btn-lg" %>
</div>

<% end %>

</div>

</div>

<div class="text-center mt-3">
  <%= link_to "Show all venues", venues_path, class: "btn btn-primary" %>
   <%= link_to "← Back", request.referer || venues_path,
      class: "btn btn-outline-dark rounded-pill px-4" %>
</div>
</div>

</div>

</div>