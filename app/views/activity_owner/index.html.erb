
<div class="container mt-5">
  <h2 class="text-center fw-bold mb-5">Activities Dashboard</h2>
   <div class="text-end">
     <%= link_to "← Back", request.referer || root_path, class: "btn  btn-dark rounded-pill px-3" %>
     </div>

  
  <h4 class="mb-4 text-primary">Upcoming Events</h4>
<% if @upcoming_activities.present? %>

  <div class="row">

    <% @upcoming_activities.each do |activity| %>
      <div class="col-md-4 mb-4">
        <div class="event-card bg-warning">

          <div class="event-header">
            <h5><%= activity.event.name %></h5>
            <span>
              <%= activity.event.start_date.strftime("%B %d, %Y") %>, 
            </span>
          </div>
          <div class="text-center mt-3">
            <%= link_to "View Details", event_path(activity.event), class: "view-btn" %>
            <span class="status-badge upcoming">Upcoming</span>
          </div>

        </div>
      </div>

    <% end %>
  </div>
   <div class="simple-pagination mt-4">
          <%= will_paginate @upcoming_activities, previous_label: "Prev", next_label: "Next" %>
        </div>
  <% else %>
      <div class="col-12">
        <p class="text-center text-muted">No upcoming events found.</p>
      </div>

      <% end %>

 
  <hr class="my-5">

 
  <h4 class="mb-4 text-secondary">Completed Activities</h4>

  <div class="row">
    <% @past_activities.each do |activity| %>
      <div class="col-md-4 mb-4">
        <div class="event-card completed-card">

          <div class="event-header">
            <h5><%= activity.event.name %></h5>
            <span>
              <%= activity.event.start_date.strftime("%B %d, %Y") %>
            </span>
          </div>

          <div class="text-center mt-3">
            <%= link_to "View Details", event_path(activity.event), class: "view-btn" %>
            <span class="status-badge completed">Completed</span>
          </div>

        </div>
      </div>

    <% end %>
  </div>
   <div class="simple-pagination mt-4">
          <%= will_paginate @past_activities, previous_label: "Prev", next_label: "Next" %>
        </div>

</div>