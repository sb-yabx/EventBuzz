<div class="container py-5">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">My Activities</h2>
  </div>

  <% if @activities.any? %>

    <% @activities.each do |activity| %>

      <div class="w-100 mb-3">

        <div class="bg-white shadow-sm rounded-4 p-4 d-flex justify-content-between align-items-center flex-wrap">

          <!-- LEFT SECTION -->
          <div>

            <!-- TITLE -->
            <h5 class="fw-bold mb-1">
              <%= activity.activity_name %>
            </h5>

            <!-- EVENT -->
            <p class="small text-muted mb-1">
              📌 <strong><%= activity.event&.name %></strong>
            </p>

            <!-- DESCRIPTION -->
            <p class="small text-muted mb-2">
              <%= truncate(activity.activity_description, length: 100) %>
            </p>

            <!-- TIME -->
            <p class="small text-muted mb-0">
              ⏰ 
              <%= activity.start_time.strftime("%d %b • %I:%M %p") %> 
              -
              <%= activity.end_time.strftime("%I:%M %p") %>
            </p>

          </div>

          <!-- RIGHT SECTION -->
          <div class="d-flex gap-2 mt-3 mt-md-0">

            <%= link_to "View Event",
                  event_path(activity.event),
                  class: "btn btn-outline-dark btn-sm rounded-pill px-3" %>

            <%= link_to "Edit",
                  edit_event_activity_path(activity.event, activity),
                  class: "btn btn-dark btn-sm rounded-pill px-3" %>

          </div>

        </div>

      </div>

    <% end %>

  <% else %>

    <!-- EMPTY STATE -->
    <div class="text-center py-5">
      <h5 class="text-muted">No activities assigned</h5>
      <p class="text-muted small">You’ll see your tasks here once assigned</p>
    </div>

  <% end %>

</div>