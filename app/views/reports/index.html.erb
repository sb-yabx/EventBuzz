<div class="container py-5">

  <!-- HEADER -->
  <div class="text-center mb-5">
    <h2 class="fw-bold">Reports/Statistics</h2>
    <p class="text-muted">Overview of platform statistics</p>
  </div>

  <div class="row g-4">

    <!-- EVENT Attendece -->
    <div class="col-md-3">
      <div class="card border-0 shadow-lg rounded-4 text-center p-4 h-100">
        <div class="mb-3">
          <i class="bi bi-person-badge fs-1 text-info"></i>
        </div>
        <h6 class="text-muted">Event Report</h6>
        <h3 class="fw-bold">
          
        </h3>
        <%= link_to "View", event_reports_path, class: "btn btn-outline-info rounded-pill mt-3" %>
      </div>
    </div>

    <!-- ACTIVITY OWNERS -->
    <div class="col-md-3">
      <div class="card border-0 shadow-lg rounded-4 text-center p-4 h-100">
        <div class="mb-3">
          <i class="bi bi-people fs-1 text-warning"></i>
        </div>
        <h6 class="text-muted">RSVP Statistics</h6>
        <h3 class="fw-bold">
         
        </h3>
        <%= link_to "View", rsvp_statistics_path, class: "btn btn-outline-warning rounded-pill mt-3" %>
      </div>
    </div>

    <!-- EVENTS -->
    <div class="col-md-3">
      <div class="card border-0 shadow-lg rounded-4 text-center p-4 h-100">
        <div class="mb-3">
          <i class="bi bi-calendar-event fs-1 text-dark"></i>
        </div>
        <h6 class="text-muted">Guest Preference Report</h6>
        <h3 class="fw-bold">
        
        </h3>
        <%= link_to "View", guest_preferences_path, class: "btn btn-outline-dark rounded-pill mt-3" %>
      </div>
    </div>

    <!-- VENUES -->
    <div class="col-md-3">
      <div class="card border-0 shadow-lg rounded-4 text-center p-4 h-100">
        <div class="mb-3">
          <i class="bi bi-geo-alt fs-1 text-danger"></i>
        </div>
        <h6 class="text-muted">Venue Utilization Report</h6>
        <h3 class="fw-bold">
         
        </h3>
        <%= link_to "View", venue_utilization_path, class: "btn btn-outline-danger rounded-pill mt-3" %>
      </div>
    </div>

  </div>
</div>