<div class="container py-5">

  <!-- TOP ACTION BAR -->
  <div class="d-flex justify-content-between align-items-center mb-4">

    <h3 class="fw-bold mb-0">Employees</h3>

    <div>
      <%= link_to "← Back", request.referer || venues_path,
        class: "btn btn-outline-dark rounded-pill px-4 me-2" %>

      <%= link_to "＋ Add Employee", new_admin_employee_path,
        class: "btn btn-success rounded-pill px-4 shadow-sm" %>
    </div>

  </div>

  <div class="row justify-content-center">

    <!-- CENTERED TABLE -->
    <div class="col-lg-10 col-xl-8">

      <div class="card border-0 shadow-lg rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center rounded-top-4">
         
          <span class="badge bg-light text-dark">
            <%= @users.count { |u| ["event_manager","activity_owner"].include?(u.role) } %> Total
          </span>
        </div>

        <div class="card-body">

          <!-- EMPTY STATE -->
          <% if @users.none? { |u| ["event_manager","activity_owner"].include?(u.role) } %>
            <div class="text-center py-5">
              <i class="bi bi-people fs-1 text-muted"></i>
              <p class="mt-3 text-muted">No employees found</p>
            </div>
          <% else %>

          <!-- TABLE -->
          <div class="table-responsive">
            <table class="table align-middle table-hover">

              <thead class="table-light">
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>

              <tbody>

                <% @users.each do |user| %>
                  <% if ["event_manager","activity_owner"].include?(user.role) %>

                    <tr>

                      <!-- NAME -->
                      <td class="fw-semibold">
                        <i class="bi bi-person-circle me-2 text-secondary"></i>
                        <%= user.name %>
                      </td>

                      <!-- EMAIL -->
                      <td class="text-muted"><%= user.email %></td>

                      <!-- ROLE -->
                      <td>
                        <% if user.role == "event_manager" %>
                          <span class="badge bg-info-subtle text-info px-3 py-2 rounded-pill">
                            Event Manager
                          </span>
                        <% else %>
                          <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill">
                            Activity Owner
                          </span>
                        <% end %>
                      </td>

                      <!-- ACTIONS -->
                      <td class="text-end">

                        <%= link_to admin_employee_path(user),
                          class: "btn btn-sm btn-outline-dark rounded-pill me-2" do %>
                          <i class="bi bi-eye"></i>
                        <% end %>

                        <%= link_to admin_employee_path(user),
                          method: :delete,
                          data: { confirm: "Are you sure?" },
                          class: "btn btn-sm btn-outline-danger rounded-pill" do %>
                          <i class="bi bi-trash"></i>
                        <% end %>

                      </td>

                    </tr>

                  <% end %>
                <% end %>

              </tbody>

            </table>
          </div>

          <% end %>

        </div>
      </div>

    </div>

  </div>

</div>