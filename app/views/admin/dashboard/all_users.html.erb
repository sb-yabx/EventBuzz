<div class="container py-4 py-md-5">

  <!-- TOP ACTION BAR -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">

    <h3 class="fw-bold mb-0">Employees</h3>

    <div class="d-flex flex-column flex-sm-row gap-2 w-100 w-md-auto">
      <%= link_to "← Back", request.referer || venues_path,
        class: "btn btn-outline-dark rounded-pill px-4 w-30 w-sm-auto" %>

      <%= link_to "＋ Add Employee", new_admin_employee_path,
        class: "btn btn-success rounded-pill px-4 shadow-sm w-30 w-sm-auto" %>
    </div>

  </div>

  <div class="row justify-content-center">

    <!-- CENTERED TABLE -->
    <div class="col-12 col-lg-10 col-xl-8">

      <div class="card border-0 shadow-lg rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center rounded-top-4 flex-wrap gap-2">
          
          <span class="fw-semibold">Employee List</span>

          <span class="badge bg-light text-dark">
            <%= @users.count { |u| ["event_manager","activity_owner"].include?(u.role) } %> Total
          </span>
        </div>

        <div class="card-body">

          <!-- EMPTY STATE -->
          <% if @users.none? { |u| ["event_manager","activity_owner"].include?(u.role) } %>
            <div class="text-center py-5">
              <i class="bi bi-people fs-1 text-muted"></i>
              <p class="mt-3 text-muted">No employees found</p>
            </div>
          <% else %>

          <!-- TABLE -->
          <div class="table-responsive">
            <table class="table align-middle table-hover">

              <thead class="table-light">
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th class="text-md-end">Actions</th>
                </tr>
              </thead>

              <tbody>

                <% @users.each do |user| %>
                  <% if ["event_manager","activity_owner"].include?(user.role) %>

                    <tr>

                      <!-- NAME -->
                      <td class="fw-semibold">
                        <i class="bi bi-person-circle me-2 text-secondary"></i>
                        <%= user.name %>
                      </td>

                      <!-- EMAIL -->
                      <td class="text-muted"><%= user.email %></td>

                      <!-- ROLE -->
                      <td>
                        <% if user.role == "event_manager" %>
                          <span class="badge bg-info-subtle text-info px-3 py-2 rounded-pill">
                            Event Manager
                          </span>
                        <% else %>
                          <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill">
                            Activity Owner
                          </span>
                        <% end %>
                      </td>

                      <!-- ACTIONS -->
                      <td>
                        <div class="d-flex flex-column flex-md-row gap-2 justify-content-md-end">

                          <%= link_to admin_employee_path(user),
                            class: "btn btn-sm btn-outline-dark rounded-pill w-100 w-md-auto" do %>
                            <i class="bi bi-eye"></i>
                          <% end %>

                          <%= link_to admin_employee_path(user),
                            method: :delete,
                            data: { confirm: "Are you sure?" },
                            class: "btn btn-sm btn-outline-danger rounded-pill w-100 w-md-auto" do %>
                            <i class="bi bi-trash"></i>
                          <% end %>

                        </div>
                      </td>

                    </tr>

                  <% end %>
                <% end %>

              </tbody>

            </table>
          </div>

          <% end %>
          <div class="simple-pagination mt-4">
          <%= will_paginate @users, previous_label: "Prev", next_label: "Next" %>
        </div>

        </div>
      </div>

    </div>

  </div>

</div>

