<div class="container py-5">

  <!-- HEADER -->
  <div class="text-center mb-5">
    <h2 class="fw-bold">Admin Dashboard</h2>
    <p class="text-muted">Overview of platform statistics</p>
  </div>

  <div class="row g-4">

    <!-- EVENT MANAGERS -->
    <div class="col-md-3">
      <div class="card border-0 shadow-lg rounded-4 text-center p-4 h-100">
        <div class="mb-3">
          <i class="bi bi-person-badge fs-1 text-info"></i>
        </div>
        <h6 class="text-muted">Event Managers</h6>
        <h3 class="fw-bold">
          <%= @event_managers %>
        </h3>
        <%= link_to "View All", show_event_managers_path, class: "btn btn-outline-info rounded-pill mt-3" %>
      </div>
    </div>

    <!-- ACTIVITY OWNERS -->
    <div class="col-md-3">
      <div class="card border-0 shadow-lg rounded-4 text-center p-4 h-100">
        <div class="mb-3">
          <i class="bi bi-people fs-1 text-warning"></i>
        </div>
        <h6 class="text-muted">Activity Owners</h6>
        <h3 class="fw-bold">
          <%= @activity_owners %>
        </h3>
        <%= link_to "View All", show_activity_owners_path, class: "btn btn-outline-warning rounded-pill mt-3" %>
      </div>
    </div>

    <!-- EVENTS -->
    <div class="col-md-3">
      <div class="card border-0 shadow-lg rounded-4 text-center p-4 h-100">
        <div class="mb-3">
          <i class="bi bi-calendar-event fs-1 text-dark"></i>
        </div>
        <h6 class="text-muted">Events</h6>
        <h3 class="fw-bold">
          <%= @events %>
        </h3>
        <%= link_to "View All", events_path, class: "btn btn-outline-dark rounded-pill mt-3" %>
      </div>
    </div>

    <!-- VENUES -->
    <div class="col-md-3">
      <div class="card border-0 shadow-lg rounded-4 text-center p-4 h-100">
        <div class="mb-3">
          <i class="bi bi-geo-alt fs-1 text-danger"></i>
        </div>
        <h6 class="text-muted">Venues</h6>
        <h3 class="fw-bold">
          <%= @venues %>
        </h3>
        <%= link_to "View All", venues_path, class: "btn btn-outline-danger rounded-pill mt-3" %>
      </div>
    </div>

  </div>
</div>