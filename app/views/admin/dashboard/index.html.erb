<div class="container mt-4">
<div class="row">

    <h2 class="text-center mb-3">Admin Dashboard</h2>

<!-- LEFT SIDE : EMPLOYEES -->
<div class="col-md-7">

<div class="card shadow-sm">
<div class="card-header bg-dark text-white">
All Employees
</div>

<div class="card-body">

<table class="table table-hover">
<thead>
<tr>
<th>Name</th>
<th>Email</th>
<th>Role</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<% @users.each do |user| %>
<% if ["event_manager","activity_owner"].include?(user.role) %>

<tr>
<td><%= user.name %></td>
<td><%= user.email %></td>
<td><%= user.role.humanize %></td>

<td>

<%= link_to "Show" , admin_employee_path(user), class:"btn btn-outline-primary btn-sm"%>
<%= link_to "Remove" , admin_employee_path(user), method: :delete ,class:"btn btn-outline-primary btn-sm"%>
</td>

</tr>

<% end %>
<% end %>

</tbody>
</table>

</div>
</div>

</div>


<!-- RIGHT SIDE -->
<div class="col-md-5">

<!-- EVENT MANAGERS CARD -->
<div class="card shadow-sm mb-4">

<div class="card-header bg-info text-white">
Event Managers
</div>

<div class="card-body text-center">

<p class="mb-3">
Total: <%= @users.count{|u| u.role == "event_manager"} %>
</p>

<%= link_to "Show all", show_event_managers_path , class: "btn btn primary"%>

</div>

</div>


<!-- ACTIVITY OWNERS CARD -->
<div class="card shadow-sm">

<div class="card-header bg-warning text-white">
Activity Owners
</div>

<div class="card-body text-center">

<p class="mb-3">
Total: <%= @users.count{|u| u.role == "activity_owner"} %>
</p>

<%= link_to "Show all", show_activity_owners_path, class: "btn btn-warning" %>

</div>

</div>
<br>

<!-- Events CARD -->
<div class="card shadow-sm">

<div class="card-header bg-dark text-white">
Events
</div>

<div class="card-body text-center">

<p class="mb-3">
Total: <%= @users.count{|u| u.role == "activity_owner"} %>
</p>
<%= link_to "Show all", events_path, class: "btn btn-dark"%>

</div>

</div>
<br>

<!-- Venue CARD -->
<div class="card shadow-sm">

<div class="card-header bg-danger text-white">
Venues
</div>

<div class="card-body text-center">

<p class="mb-3">
Total: <%= @venues.count %>
</p>

<%= link_to "Show all", venues_path, class: "btn btn-primary" %>
</div>

</div>

</div>

</div>
</div>