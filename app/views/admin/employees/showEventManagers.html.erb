<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">All Event Mangers</h2>
    <div class="d-flex gap-2">
     <%= link_to "← Back", request.referer || root_path, class: "btn bg-dark btn-dark rounded-pill px-3" %>
    <%= link_to "Add New Event Manager", new_admin_employee_path, class: "btn btn-success" %>
  </div>
  </div>

  <div class="card shadow-sm">

    <div class="card-header bg-dark text-white">
      Venue List
    </div>

    <div class="card-body">

      <% if @event_managers.any? %>

      <table class="table table-hover table-striped align-middle">

        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>

        <% @event_managers.each do |manager| %>
          <tr>

            <td>
              <strong><%= manager.name %></strong>
            </td>

            <td>
              <%= manager.email %>
            </td>

            <td>

              <%= link_to "Show", admin_employee_path(manager),class: "btn btn-sm btn-outline-danger" %>

             <%= link_to "Delete", admin_employee_path(manager),
                 method: :delete,
                data: { confirm: "Are you sure?" },
                class: "btn btn-sm btn-outline-danger" %>
            </td>
             <td>

          </tr>
        <% end %>

        </tbody>

      </table>


      <% else %>

      <p class="text-center text-muted">No venues found.</p>

      <% end %>

    </div>

  </div>

</div>