<div class="container py-5">

  <!-- USER PROFILE CARD -->
  <div class="card border-0 shadow-lg rounded-4 mb-5">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap">

      <div>
        <h2 class="fw-bold mb-1"><%= @user.name %></h2>
        <p class="text-muted mb-2"><%= @user.email %></p>

        <% if @user.role == "event_manager" %>
          <span class="badge bg-primary px-3 py-2">Event Manager</span>
        <% elsif @user.role == "activity_owner" %>
          <span class="badge bg-success px-3 py-2">Activity Owner</span>
        <% else %>
          <span class="badge bg-secondary px-3 py-2"><%= @user.role %></span>
        <% end %>
      </div>

      <!-- Optional Avatar -->
      <div class="text-center">
        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center"
             style="width:80px;height:80px;font-size:28px;">
          <%= @user.name.first.upcase %>
        </div>
      </div>

    </div>
  </div>

  <!-- SECTION TITLE -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <% if @user.role == "event_manager" %>
      <h4 class="fw-semibold">Events Managed</h4>
    <% elsif @user.role == "activity_owner" %>
      <h4 class="fw-semibold">Activities Created</h4>
    <% end %>
  </div>

  <!-- EVENTS GRID -->
  <% if @events.any? %>
    <div class="row g-4">

      <% @events.each do |event| %>
        <div class="col-md-4">

          <div class="card border-0 shadow-sm rounded-4 h-100 event-card" style="background-color:#181615">

            <div class="card-body d-flex flex-column text-white">

              <!-- Title -->
              <h5 class="fw-bold mb-3"><%= event.name %></h5>

              <p class=" mb-1 text-white">
                📅 <%= event.date.strftime("%d %b") %>
                • ⏰ <%= event.start_time.strftime("%I:%M %p") %>
                </p>


              <p class="text-white mb-3">
                📍<%= event.venue&.name %> <br> <%= event.venue&.address %>
              </p>

              <!-- Spacer -->
              <div class="mt-auto">
                <%= link_to "View Details", event_path(event),
                  class: "btn btn-dark w-100 rounded-pill" %>
              </div>

            </div>

          </div>

        </div>
      <% end %>

    </div>
  <% else %>

    <!-- Empty State -->
    <div class="text-center py-5">
      <h5 class="text-muted">No events found</h5>
      <p class="text-muted small">This user hasn’t created any events yet.</p>
    </div>

  <% end %>

  <!-- BACK BUTTON -->
  <div class="mt-5">
    <%= link_to "← Back", request.referer || root_path,
      class: "btn btn-outline-dark rounded-pill px-4" %>
  </div>

</div>