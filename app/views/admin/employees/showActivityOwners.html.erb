<div class="container py-4 py-md-5">

  <!-- TOP BAR -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
    
    <h2 class="fw-bold mb-0">All Activity Owners</h2>

    <div class="d-flex flex-column flex-sm-row gap-2 w-100 w-md-auto">
      <%= link_to "← Back",
        request.referer || root_path,
        class: "btn btn-dark rounded-pill px-3  w-sm-auto" %>

      <%= link_to "Add New Activity Owner",
        new_admin_employee_path,
        class: "btn btn-success  w-sm-auto" %>
    </div>

  </div>

  <!-- CARD -->
  <div class="card shadow-sm border-0">

    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center flex-wrap gap-2">
      <span>Activity Owners</span>
      <span class="badge bg-light text-dark">
        <%= @activity_owners.count %> Total
      </span>
    </div>

    <div class="card-body">

      <% if @activity_owners.any? %>

        <!-- RESPONSIVE TABLE -->
        <div class="table-responsive">
          <table class="table table-hover table-striped align-middle">

            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th class="text-md-end">Actions</th>
              </tr>
            </thead>

            <tbody>

              <% @activity_owners.each do |owner| %>
                <tr>

                  <!-- NAME -->
                  <td class="fw-semibold">
                    <i class="bi bi-person-circle me-2 text-secondary"></i>
                    <%= owner.name %>
                  </td>

                  <!-- EMAIL -->
                  <td class="text-muted">
                    <%= owner.email %>
                  </td>

                  <!-- ACTIONS -->
                  <td>
                    <div class="d-flex flex-column flex-md-row gap-2 justify-content-md-end">

                      <%= link_to "View",
                        admin_employee_path(owner),
                        class: "btn btn-sm btn-outline-dark rounded-pill w-100 w-md-auto" %>

                      <%= link_to "Delete",
                        admin_employee_path(owner),
                        method: :delete,
                        data: { confirm: "Are you sure?" },
                        class: "btn btn-sm btn-outline-danger rounded-pill w-100 w-md-auto" %>

                    </div>
                  </td>

                </tr>
              <% end %>

            </tbody>

          </table>
        </div>

      <% else %>

        <div class="text-center py-5">
          <i class="bi bi-people fs-1 text-muted"></i>
          <p class="mt-3 text-muted">No Activity Owners found</p>
        </div>

      <% end %>

    </div>

  </div>

</div>

