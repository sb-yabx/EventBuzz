<div class="hero-section">
  <div class="hero-overlay"></div>

  <div class="hero-box">
    <h1 class="main-heading">EventBuzz</h1>
    <p class="tagline">Discover the Buzz Around Every Event</p>

    <% if !current_user %>
      <div class="auth-buttons">
        <%= link_to "Login", new_user_session_path, class: "btn btn-light" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-outline" %>
      </div>
    <% end %>
  </div>
</div>

<!-- EVENTS SECTION -->
<div class="events-section">
  <h2 class="section-title">Featured Events</h2>

  <div class="events-grid">
    <% events = [
      {title: "Music Festival", img: "https://images.unsplash.com/photo-1506157786151-b8491531f063"},
      {title: "Startup Conference", img: "https://images.unsplash.com/photo-1511578314322-379afb476865"},
      {title: "Creative Workshops", img: "https://images.unsplash.com/photo-1523580494863-6f3031224c94"},
      {title: "Art & Culture", img: "https://images.unsplash.com/photo-1497032205916-ac775f0649ae"}
    ] %>

    <% events.each do |event| %>
      <div class="event-card" onclick="window.location='#'">
        <img src="<%= event[:img] %>">
        <div class="event-content">
          <h3><%= event[:title] %></h3>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- ABOUT SECTION -->
<div class="about-section">
  <div class="about-container">
    <h2>About EventBuzz</h2>
    <p>
      EventBuzz is your go-to platform for discovering, managing, and experiencing events like never before.
      Whether it's music festivals, corporate conferences, creative workshops, or cultural gatherings — 
      we bring everything together in one place.
    </p>

    <p>
      Our mission is to connect people with experiences that matter. Event organizers can seamlessly create 
      and manage events, while users can explore, register, and stay updated with the latest happenings.
    </p>

    <div class="about-highlights">
      <div><i class="fa-solid fa-ticket"></i> Easy Event Booking</div>
      <div><i class="fa-solid fa-bullhorn"></i> Smart Event Management</div>
      <div><i class="fa-solid fa-earth-americas"></i> Discover Local & Global Events</div>
      <div><i class="fa-solid fa-bolt"></i> Real-time Updates</div>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-container">
    
    <div class="footer-left">
      <h3>EventBuzz</h3>
      <p>Discover the Buzz Around Every Event</p>
    </div>

    <div class="footer-social">
      <p>Follow Us</p>
      <div>
        <a href="https://www.youtube.com/" target=_blank ><i class="fa-solid fa-earth-americas"></i></a>
        <a href="https://www.instagram.com/?hl=en" target= _blank><i class="fa-solid fa-camera"></i></a>
        <a href="https://x.com/?lang=en" target=_blank><i class="fa-brands fa-twitter"></i></a>
      </div>
    </div>

  </div>

  <p class="footer-bottom">© <%= Time.now.year %> EventBuzz. All rights reserved.</p>
</footer>