<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">All Events</h2>
  <div class="d-flex gap-2">
     <%= link_to "← Back", request.referer || root_path, class: "btn bg-dark btn-dark rounded-pill px-3" %>
    <%= link_to "Add New Event", new_event_path, class: "btn btn-success" %>
     </div>
  </div>

  <div class="card shadow-sm">

    <div class="card-header bg-dark text-white">
      Event List
    </div>

    <div class="card-body">

      <% if @events.any? %>

      <table class="table table-hover table-striped align-middle">

        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Date</th>
            <th>Event Manager</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>

        <% @events.each do |event| %>
          <tr>

            <td>
              <strong><%= event.name %></strong>
            </td>

            <td>
              <%= event.date %>
            </td>
             <td>
              <%= event.event_manager.name %>
            </td>
             

            <td>
               <% if event.date < Date.today%>
                <%= link_to "Show", event_path(event), class: "btn btn-sm btn-outline-warning" %>
                <button class="btn btn-sm btn-dark" disabled>Event done</button>
               <%else%>
               <%= link_to "Edit", edit_event_path(event), class: "btn btn-sm btn-outline-warning" %>
              

              <%= link_to "Delete", event_path(event),
                  method: :delete,
                  data: { confirm: "Are you sure?" },
                  class: "btn btn-sm btn-outline-danger" %>
               <%end%>
             
             
            </td>

          </tr>
        <% end %>

        </tbody>

      </table>


      <% else %>

      <p class="text-center text-muted">No venues found.</p>

      <% end %>

    </div>


  </div>
</div>