<% if @event.errors.any? %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% @event.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>


<div class="container mt-5">

<div class="row justify-content-center">
<div class="col-md-6">

<div class="card shadow-lg border-0">

<div class="card-header bg-dark text-white text-center">
<h4>Add New Event</h4>
</div>

<div class="card-body">

<%= form_with model: @event do |f| %>

<div class="mb-3">
<%= f.label :name, "Event Name", class:"form-label" %>
<%= f.text_field :name, class:"form-control", placeholder:"Enter event name" %>
</div>

<div class="mb-3">
<%= f.label :venue, class:"form-label" %>
<%= f.select :venue_id,
      Venue.all.map{|u| [u.name, u.id]},
      {prompt: "Select Venue"},
      class:"form-select"%>
</div>


<div class="row">

<div class="col-md-6 mb-3">
<%= f.label :date, "Start date",class:"form-label" %>
<%= f.date_field :date, class:"form-control" , required: true %>
</div>

<div class="col-md-6 mb-3">
<%= f.label :end_Date, "End date",class:"form-label" %>
<%= f.date_field :end_date, class:"form-control" , required: true %>
</div>

</div>

<div class="row">

<div class="col-md-6 mb-3">
<%= f.label :start_time, "Start Time", class:"form-label" %>
<%= f.time_field :start_time, class:"form-control" %>
</div>

<div class="col-md-6 mb-3">
<%= f.label :end_time, "End Time", class:"form-label" %>
<%= f.time_field :end_time, class:"form-control" %>
</div>

</div>


<div class="row">
<div class="col-md-6 mb-3">
<%= f.label :event_manager_id, "Event Manager", class:"form-label" %>
<%= f.select :event_manager_id,
      User.where(role:"event_manager").map{|u| [u.name,u.id]},
      {prompt:"Select Event Manager"},
      class:"form-select" %>
</div>

<div class="col-md-6 mb-3">
<%= f.label :capacity, "Capacity", class:"form-label" %>
<%= f.number_field :capacity, class:"form-control", min: 0%>
</div>
</div>


<div class="mb-3">
<%= f.label :description, class:"form-label" %>
<%= f.text_area :description,
      class:"form-control",
      rows:3,
      placeholder:"Write event details..." %>
</div>

<div class="d-grid">
<%= f.submit "Create Event", class:"btn btn-primary btn-lg" %>
</div>

<% end %>

</div>
</div>

</div>
</div>

</div>