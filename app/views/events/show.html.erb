<div class="container py-5">

  <div class="card border-0 shadow-lg rounded-4 mb-5">
    <div class="card-body p-5">

      <!-- TOP ROW -->
      <div class="d-flex justify-content-between align-items-start">

        <!-- LEFT: TITLE -->
        <h3 class="fw-bold display-6 mb-3">
          <%= @event.name %>
        </h3>

        <!-- RIGHT: STATUS -->
        <div>
          <% if @event.start_date == Date.today %>
            <span class="badge bg-success px-4 py-2 fs-6">Today</span>
          <% elsif @event.start_date > Date.today %>
            <span class="badge bg-primary px-4 py-2 fs-6">Upcoming</span>
          <% else %>
            <span class="badge bg-secondary px-4 py-2 fs-6">Completed</span>
          <% end %>
        </div>

      </div>

      <!-- DESCRIPTION -->
      <p class="text-muted mb-4" style="max-width:600px;">
        <%= @event.description %>
      </p>

      <!-- DETAILS -->
      <div class="row mb-4">

        <div class="col-md-6">
          <% if @event.start_date == @event.end_date%>
          <p><i class="fa-regular fa-calendar"></i> <%= @event.start_date.strftime("%d %b %Y") %></p>
          <%else%>
           <p><i class="fa-regular fa-calendar"></i> <%= @event.start_date.strftime("%d %b %Y")%> - <%= @event.end_date.strftime("%d %b %Y")%> </p>
          <%end%>
          <p><i class="fa-solid fa-people-robbery"></i> Capacity: <%= @event.capacity %></p>
        </div>

        <div class="col-md-6 text-md-end">
          <p>
           <i class="fa-solid fa-map-pin"></i> <strong>
              <%= @event.venue&.name %>, 
              <%= @event.venue&.address %>
            </strong>
          </p>
        </div>

      </div>

      <!-- FULL WIDTH MAP -->
      <div class="rounded-4 overflow-hidden shadow-sm mb-4">
        <iframe
          width="100%"
          height="350"
          style="border:0"
          loading="lazy"
          src="https://www.google.com/maps?q=<%= ERB::Util.url_encode(@event.venue&.address.to_s) %>&output=embed">
        </iframe>
      </div>

      <!-- ACTION BUTTONS BELOW MAP -->
      <div class="d-flex justify-content-end gap-2 flex-wrap">

        <% if current_user == @event.event_manager %>
          <%= link_to "Edit",
                edit_event_path(@event),
                class: "btn btn-dark rounded-pill px-4" %>
        <% end %>

        <% rsvp = @event.rsvps.find_by(user_id: current_user.id) %>

        <% if rsvp && rsvp.pending? && @event.start_date.strftime("%Y-%m-%d") > Date.today.strftime("%Y-%m-%d") %>
          <%= link_to "Fill RSVP",
                new_event_rsvp_path(@event),
                class: "btn btn-dark rounded-pill px-4" %>
        <% end %>

        <%= link_to "← Back",
              request.referer || root_path,
              class: "btn btn-outline-dark rounded-pill px-4" %>

      </div>

    </div>
  </div>

  <!-- DASHBOARD STRIP -->
  <% if current_user.role == "event_manager" || current_user.role == "activity_owner" || current_user.role == "admin"%>
    <div class="card border-0 shadow-sm rounded-4 mb-4">
      <div class="row text-center text-white g-0" style="background-color:#b42508">

        <% if @event.event_manager %>
          <%= link_to admin_employee_path(@event.event_manager),
              class: "col-md-4 border-end py-3 text-white text-decoration-none" do %>

            <small class="d-block">Event Manager</small>
            <strong><%= @event.event_manager.name %></strong>

          <% end %>
        <% end %>

        <%= link_to special_requests_event_rsvps_path(@event),
            class: "col-md-4 border-end py-3 text-white text-decoration-none" do %>

          <small class="d-block">Guests</small>
          <strong>
            Special Requests 
            (<%= @event.rsvps.where.not(special_request: [nil, ""]).count %>)
          </strong>

        <% end %>

        <%= link_to event_rsvps_path(@event),
            class: "col-md-4 py-3 text-white text-decoration-none" do %>

          <small class="d-block">Guests</small>
          <strong>RSVP Details</strong>

        <% end %>

      </div>
    </div>
  <% end %>

  <!-- ACTIVITIES -->
  <div class="mt-5">

    <h3 class="fw-bold mb-4">Activities</h3>

    <% if @activities.any? %>

      <% @activities.each do |activity| %>

        <div class="mb-3">
          <div class="border-0 shadow-sm rounded-4 bg-white p-4 d-flex justify-content-between align-items-center flex-wrap">

            <div>
              <h5 class="fw-bold mb-2"><%= activity.activity_name %></h5>

              <p class="small text-primary fw-semibold mb-1">
                <p><i class="fa-solid fa-people-robbery"></i> <%= activity.user&.name || "No Owner Assigned" %>
              </p>

              <p class="text-muted small mb-2">
                <%= activity.activity_description %>
              </p>

            </div>

            <% if current_user == activity.user || current_user.id == @event.event_manager_id %>
              <div class="d-flex gap-2">
                <%= link_to "Edit",
                      edit_event_activity_path(@event, activity),
                      class: "btn btn-outline-dark btn-sm rounded-pill px-3" %>

                <%= link_to "Show",
                      event_activity_path(@event, activity),
                      class: "btn btn-outline-dark btn-sm rounded-pill px-3" %>
              </div>
            <% end %>

          </div>
        </div>

      <% end %>

    <% else %>

      <p class="text-muted">No activities added yet.</p>

    <% end %>

    <% if current_user.role == "event_manager" %>
      <div class="text-center mt-4">
        <%= link_to "Add Activities",
              new_event_activity_path(@event),
              class: "btn btn-dark rounded-pill px-4" %>
      </div>
    <% end %>

  </div>

</div>