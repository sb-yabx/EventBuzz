<div class="container py-5">

  <div class="card border-0 shadow-lg rounded-4 mb-5">
  <div class="card-body p-5">

    <div class="d-flex justify-content-between align-items-start flex-wrap">

      <!-- LEFT (MAIN EVENT INFO) -->
      <div>

        <!-- BIG TITLE -->
        <h3 class="fw-bold display-5 mb-3">
          Event Name: <%= @event.name %>
        </h3>
         <p class="fs-6 text-muted">
          <%= @event.description %>
        </p>

        <!-- BIG DATE & TIME -->
        <p class="fs-4 text-dark mb-2">
          📅 <%= @event.date.strftime("%d %b %Y") %>
        </p>

        <p class="fs-4 text-dark mb-3">
          ⏰ <%= @event.start_time.strftime("%I:%M %p") %> - 
          <%= @event.end_time.strftime("%I:%M %p") %>
        </p>

        <!-- BIG VENUE -->
        <p class="fs-5 text-dark mb-0">
          📍 <strong><%= @event.venue&.name%><p class="fs-6 text-muted">
          <%= @event.venue&.address %>
        </p></strong>
        </p>

       

      </div>

      <!-- RIGHT (STATUS BADGE) -->
      <div class="mt-2">

        <% if @event.date == Date.today %>
          <span class="badge bg-success px-4 py-2 fs-6">Today</span>
        <% elsif @event.date > Date.today %>
          <span class="badge bg-primary px-4 py-2 fs-6">Upcoming</span>
        <% else %>
          <span class="badge bg-secondary px-4 py-2 fs-6">Completed</span>
        <% end %>

      </div>
      <%if current_user == @event.event_manager_id%>
          <%= link_to "Edit", edit_event_path(@event), class: "btn btn-dark rounded-pill px-4" %>
      <%end%>
      <%# Guest %>
      <% rsvp = @event.rsvps.find_by(user_id: current_user.id) %>

        <% if rsvp && rsvp.pending? && @event.date > Date.today%>
          <%= link_to "Fill RSVP",
              new_event_rsvp_path(@event),
              class: "btn btn-dark rounded-pill px-4" %>
        <% end %>

    </div>
   <div class="d-flex gap-2">
     <%= link_to "← Back", request.referer || root_path, class: "btn bg-dark btn-dark rounded-pill px-3" %>
     </div>
  </div>
</div>


<% if current_user.role == "event_manager" || current_user.role == "activity_owner"%>
 <div class="card border-0 shadow-sm rounded-4 mt-4">
  <div class="card-body py-3">

    <div class="row text-center text-white" style="background-color:#b42508">

      <!-- Event Manager -->
      <% if @event.event_manager %>
        <%= link_to admin_employee_path(@event.event_manager),
            class: "col-md-4 border-end py-3 text-white text-decoration-none dashboard-link" do %>

          <small class="d-block">Event Manager</small>
          <strong><%= @event.event_manager.name %></strong>

        <% end %>
      <% end %>

      <!-- Special Requests -->
      <%= link_to special_requests_event_rsvps_path(@event),
          class: "col-md-4 border-end py-3 text-white text-decoration-none dashboard-link" do %>

        <small class="d-block">Guests</small>
        <strong>
          Special Requests 
          (<%= @event.rsvps.where.not(special_request: [nil, ""]).count %>)
        </strong>

      <% end %>

      <!-- RSVP -->
      <%= link_to event_rsvps_path(@event),
          class: "col-md-4 py-3 text-white text-decoration-none dashboard-link" do %>

        <small class="d-block">Guests</small>
        <strong>RSVP Details</strong>

      <% end %>

    </div>

  </div>
</div>

<%end%>





  <div class="container-fluid py-5">

  <h3 class="fw-bold mb-4">Activities</h3>

  <% if @activities.any? %>

    <% @activities.each do |activity| %>

      <div class="w-100 mb-3">

        <div class="border-0 shadow-sm rounded-4 bg-white p-4 d-flex justify-content-between align-items-center flex-wrap">

          <!-- LEFT SIDE -->
          <div>

            <!-- TITLE -->
            <h5 class="fw-bold mb-2">
              <%= activity.activity_name %>
            </h5>

            <!-- OWNER -->
            <p class="small mb-1 text-primary fw-semibold">
              👤 <%= activity.user&.name || "No Owner Assigned" %>
            </p>

            <!-- DESCRIPTION -->
            <p class="text-muted small mb-2">
              <%= activity.activity_description %>
            </p>

            <!-- TIME -->
            <p class="small text-muted mb-0">
              ⏰ 
              <%= activity.start_time.strftime("%I:%M %p") %> 
              -
              <%= activity.end_time.strftime("%I:%M %p") %>
            </p>

          </div>

          <!-- RIGHT SIDE BUTTONS -->
          <%if current_user == activity.user || current_user.id == activity.event.event_manager_id%>
          <div class="mt-3 mt-md-0 d-flex gap-2">

            <%= link_to "Edit",
                  edit_event_activity_path(@event, activity),
                  class: "btn btn-outline-dark btn-sm rounded-pill px-3" %>

            <%= link_to "Show",
                  event_activity_path(@event, activity),
                  class: "btn btn-outline-dark btn-sm rounded-pill px-3" %>

          </div>
          <%end%>
          

        </div>

      </div>

    <% end %>

  <% else %>

    <div class="text-muted">
      No activities added yet.
    </div>

  <% end %>

</div>


   <% if current_user.role == "event_manager"%>
   <div class="text-center mt-3">
     <%= link_to "Add activities", new_event_activity_path(@event) , class:"btn btn-dark rounded-pill px-4"%>
   </div>
   <% end %>
      


  </div>

</div>